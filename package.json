{
  "name": "obsidian-vault-cli",
  "version": "0.1.0",
  "description": "Community-built, open-source CLI for Obsidian vaults",
  "type": "module",
  "bin": {
    "obs": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
